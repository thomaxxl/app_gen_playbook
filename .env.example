# Runtime mode for orchestrator dispatch and auto-launch behavior.
# host = run and start local app processes in this repository.
# sandbox = defer runtime launch to sandbox worker (no local app bootstrap).
PLAYBOOK_RUNTIME_ENV=host

# Skip all interactive prompts/approvals in the host CLI path (0=normal, 1=skip).
PLAYBOOK_YOLO=0

# 1 = allow the playbook to auto-start app runtime when needed.
# 0 = do not auto-start; run will block on runtime prerequisites instead.
# Frontend and backend listener ports used by capture and host preflight.
FRONTEND_PORT=5173
BACKEND_PORT=5656

# Dependency override for preexisting backend virtual environment.
# Set to a directory containing bin/python to force reuse.
BACKEND_VENV=

# Dependency override for preexisting frontend node_modules directory.
# Set to existing node_modules root to reuse instead of project-local install.
FRONTEND_NODE_MODULES_DIR=

# Dependency provisioning mode for app-level dependency handling:
# clean-install (default) = install missing deps, preprovisioned-reuse-only = validate only, don't install.
DEPENDENCY_PROVISIONING_MODE=

# Compatibility fallback model aliases if role-specific values are not set.
FAST_MODEL=
MAIN_MODEL=
LONG_MODEL=

# Explicit role models (override FAST_MODEL/MAIN_MODEL/LONG_MODEL when set).
# frontend/backend/devops default to fast model; architect/ceo/product_manager use respective roles.
PRODUCT_MANAGER_MODEL=gpt-5.4
ARCHITECT_MODEL=gpt-5.4
FRONTEND_MODEL=gpt-5.3-codex-spark
BACKEND_MODEL=gpt-5.3-codex-spark
DEVOPS_MODEL=gpt-5.3-codex-spark
DEPLOYMENT_MODEL=gpt-5.3-codex-spark
CEO_MODEL=gpt-5.4

# Shared Codex reasoning-effort setting passed to model calls.
REASONING_EFFORT=high
