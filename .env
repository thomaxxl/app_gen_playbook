PLAYBOOK_RUNTIME_ENV=host
PLAYBOOK_YOLO=0
PLAYBOOK_AUTO_START_APP=1

FRONTEND_PORT=5173
BACKEND_PORT=5656
# Set these to reuse pre-provisioned environments instead of local folders.
# BACKEND_VENV=/absolute/path/to/backend/venv-or-symlink-target
# FRONTEND_NODE_MODULES_DIR=/absolute/path/to/node_modules
BACKEND_VENV=
FRONTEND_NODE_MODULES_DIR=
DEPENDENCY_PROVISIONING_MODE=

FAST_MODEL=
MAIN_MODEL=
LONG_MODEL=

PRODUCT_MANAGER_MODEL=gpt-5.4
ARCHITECT_MODEL=gpt-5.4
FRONTEND_MODEL=gpt-5.3-codex-spark
BACKEND_MODEL=gpt-5.3-codex-spark
DEVOPS_MODEL=gpt-5.3-codex-spark
DEPLOYMENT_MODEL=gpt-5.3-codex-spark
CEO_MODEL=gpt-5.4
REASONING_EFFORT=high
