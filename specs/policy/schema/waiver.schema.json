{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://app-gen-playbook.local/specs/policy/schema/waiver.schema.json",
  "title": "Policy Waiver",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "requirement_ids", "approved_by", "status"],
  "properties": {
    "id": {"type": "string", "minLength": 1},
    "requirement_ids": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^[A-Z0-9-]+$"}
    },
    "title": {"type": "string"},
    "reason": {"type": "string"},
    "approved_by": {"type": "string", "minLength": 1},
    "status": {
      "type": "string",
      "enum": ["approved", "expired", "superseded", "rejected"]
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "roles": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "phases": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "gates": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "run_modes": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "paths": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "expires_at": {"type": "string", "minLength": 1},
    "evidence": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
